# Entorno PRODUCTION - Deployado en Vercel con Firebase
# Usar: npm run build (automáticamente usa PRODUCTION)

VITE_ENVIRONMENT=production
VITE_DEBUG=false

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=mundo-pixel-94.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=mundo-pixel-94
VITE_FIREBASE_STORAGE_BUCKET=mundo-pixel-94.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Deployed URL (Vercel)
VITE_DEPLOYED_URL=https://tienda-mundo-pixel-94.vercel.app
